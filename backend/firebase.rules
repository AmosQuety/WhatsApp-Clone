rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /groups/{groupId} {
      allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
      allow create: if request.auth != null;
      allow update, delete: if false;

      match /members/{memberId} {
        allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow create: if request.auth != null;
        allow delete: if false;
      }

      match /typing/{userId} {
        allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /messages/{messageId} {
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
          && request.resource.data.visibleTo is list
          && request.resource.data.visibleTo.size() > 0;
        allow read: if request.auth != null && (
          request.auth.uid in resource.data.visibleTo ||
          resource.data.visibleTo.hasAny(['ALL'])
        );
        allow update, delete: if false;

        match /receipts/{userId} {
          allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
          allow write: if request.auth != null && request.auth.uid == userId;
        }

        match /reactions/{userId} {
          allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
          allow write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
    match /calls/{callId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == resource.data.callerId || 
        request.auth.uid == resource.data.recipientId ||
        request.auth.uid == request.resource.data.callerId
      );
    }
  }
}
